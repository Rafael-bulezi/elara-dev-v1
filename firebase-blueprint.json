{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product listed for sale by a user.",
      "type": "object",
      "properties": {
        "sellerName": { "type": "string", "description": "Name of the seller or company" },
        "productName": { "type": "string", "description": "Name of the product" },
        "price": { "type": "number", "description": "Price in Kwanzas" },
        "description": { "type": "string", "description": "Product description" },
        "imageUrl": { "type": "string", "description": "URL of the product image" },
        "status": { "type": "string", "enum": ["Pendente de Aprovação", "Aprovado"], "description": "Approval status" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["sellerName", "productName", "price", "status"]
    },
    "Order": {
      "title": "Order",
      "description": "A purchase order from a customer.",
      "type": "object",
      "properties": {
        "customerName": { "type": "string", "description": "Name of the customer" },
        "address": { "type": "string", "description": "Delivery address" },
        "phone": { "type": "string", "description": "Customer phone number" },
        "paymentMethod": { "type": "string", "description": "Payment method (e.g., Multicaixa)" },
        "items": { "type": "array", "description": "List of products in the order" },
        "total": { "type": "number", "description": "Total order value" },
        "status": { "type": "string", "enum": ["Recebido", "Em Processamento", "Concluído"], "description": "Order status" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Order timestamp" }
      },
      "required": ["customerName", "address", "phone", "paymentMethod", "items", "total"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of products for sale."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of purchase orders."
    },
    "/mail/{mailId}": {
      "schema": "object",
      "description": "Collection for Trigger Email extension."
    }
  }
}
